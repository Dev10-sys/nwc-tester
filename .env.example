# Lightning Wallet Tester - Environment Variables
# No environment variables are required for this application!
# All configuration is handled client-side through localStorage

# Optional: Analytics (if you want to add your own)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Optional: Custom Lightning Address (for the Zap interface)
# NEXT_PUBLIC_LIGHTNING_ADDRESS=yourname@getalby.com
